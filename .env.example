# NovaAgent · Phase 1 environment template
# --------------------------------------------------------------
# 1. 在你本机把 NOVAAGENT_API_KEY 替换成你的 Key
# 2. 其余变量按需启用 / 调整

# ---- 必选：LLM API Key（智谱 GLM / DeepSeek / Kimi / StepFun 等） ----
NOVAAGENT_API_KEY=
#接入DeepSeek的API
# ---- 可选：自定义 Base URL / 模型 ----
# NOVAAGENT_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
# NOVAAGENT_MODEL=glm-5.1

# ---- 可选：网络搜索 ----
# 如果不设置，会自动复用 NOVAAGENT_API_KEY
# NOVAAGENT_WEBSEARCH_KEY=your_websearch_key_here
# NOVAAGENT_WEBSEARCH_URL=https://open.bigmodel.cn/api/paas/v4/web_search

# ---- 可选：Agent 调优 ----
# NOVAAGENT_PROJECT_ROOT=/path/to/project

# ---- 关闭颜色输出（可选） ----
# NO_COLOR=1
